# Server
PORT=5000
NODE_ENV=production
# BACKEND_URL=http://localhost:5000
BACKEND_URL=https://desktop-application-postman.onrender.com
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=https://your-frontend-url.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/postman-like-app?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Session (used briefly during OAuth flow)
SESSION_SECRET=your-session-secret-change-this

# CORS Configuration
# For local development:
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# For production (add your frontend URL):
CORS_ORIGIN=https://your-production-url.com

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth deep-link scheme for Electron (keep as postmanlike)
OAUTH_CALLBACK_SCHEME=postmanlike

# NVIDIA AI API — https://build.nvidia.com/
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=your-nvidia-api-key
AI_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
AI_FALLBACK_MODEL=meta/llama-3.1-8b-instruct

# Email Configuration
EMAIL_USER=apiflow.support@gmail.com
EMAIL_PASS=your-gmail-app-password
# SMTP Server Settings (Defaults to Gmail if not set)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true

# Alternative Email API Configuration (Bypasses SMTP port blocking on hosts like Render)
# RESEND_API_KEY=re_your_api_key_here
# RESEND_FROM=onboarding@resend.dev
# BREVO_API_KEY=your_brevo_api_key_here


# Collaboration Settings (Optional - uses defaults if not set)
# Maximum concurrent users per workspace (default: 50)
MAX_USERS_PER_WORKSPACE=50
# Session timeout in minutes (default: 30)
COLLABORATION_SESSION_TIMEOUT=30
# Invitation expiry in days (default: 7)
INVITATION_EXPIRY_DAYS=7